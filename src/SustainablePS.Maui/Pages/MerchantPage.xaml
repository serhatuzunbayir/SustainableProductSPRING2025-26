<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SustainablePS.Maui.Pages.MerchantPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Merchant Console"
    BackgroundColor="#F7F8FA">

    <Grid
        RowDefinitions="Auto,*"
        RowSpacing="16"
        Padding="20,16">

        <Grid
            ColumnDefinitions="*,Auto"
            ColumnSpacing="16">

            <VerticalStackLayout Spacing="6">
                <Label
                    Text="SustainablePS Merchant"
                    FontSize="28"
                    FontAttributes="Bold" />

                <Label
                    x:Name="SubtitleLabel"
                    Text="Manage products, stock, orders, and merchant notifications."
                    FontSize="13"
                    TextColor="{StaticResource Muted}"
                    LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <HorizontalStackLayout
                Grid.Column="1"
                Spacing="8"
                VerticalOptions="Center">

                <Button
                    x:Name="RefreshButton"
                    Text="Refresh"
                    Style="{StaticResource SecondaryButton}"
                    Clicked="OnRefreshClicked"
                    IsVisible="False"
                    HeightRequest="42"
                    CornerRadius="10" />

                <Button
                    x:Name="LogoutButton"
                    Text="Logout"
                    Style="{StaticResource SecondaryButton}"
                    Clicked="OnLogoutClicked"
                    IsVisible="False"
                    HeightRequest="42"
                    CornerRadius="10" />
            </HorizontalStackLayout>
        </Grid>

        <Border
            x:Name="LoginPanel"
            Grid.Row="1"
            Style="{StaticResource CardFrame}"
            MaximumWidthRequest="520"
            HorizontalOptions="Center"
            VerticalOptions="Start"
            Padding="20"
            BackgroundColor="White">

            <VerticalStackLayout Spacing="12">
                <Label
                    Text="Merchant Login"
                    FontSize="22"
                    FontAttributes="Bold" />

                <Label
                    Text="Use the demo merchant account or register a merchant in the web app first."
                    FontSize="13"
                    TextColor="{StaticResource Muted}"
                    LineBreakMode="WordWrap" />

                <Entry
                    x:Name="LoginEmailEntry"
                    Placeholder="Email"
                    Keyboard="Email"
                    HeightRequest="44" />

                <Entry
                    x:Name="LoginPasswordEntry"
                    Placeholder="Password"
                    IsPassword="True"
                    HeightRequest="44" />

                <Button
                    Text="Login"
                    Clicked="OnLoginClicked"
                    HeightRequest="46"
                    CornerRadius="12"
                    Margin="0,4,0,0" />

                <Label
                    Text="Demo: merchant@sustainable.test / demo123"
                    TextColor="{StaticResource Muted}"
                    FontSize="12" />
            </VerticalStackLayout>
        </Border>

        <ScrollView
            x:Name="ConsolePanel"
            Grid.Row="1"
            IsVisible="False">

            <Grid
                ColumnDefinitions="1.05*,1.25*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="16"
                RowSpacing="16">

                <Border
                    Style="{StaticResource CardFrame}"
                    Padding="16"
                    BackgroundColor="White">

                    <VerticalStackLayout Spacing="12">
                        <Grid
                            ColumnDefinitions="*,Auto"
                            ColumnSpacing="8">

                            <VerticalStackLayout Spacing="4">
                                <Label
                                    x:Name="EditorTitleLabel"
                                    Text="Add Product"
                                    FontSize="20"
                                    FontAttributes="Bold" />

                                <Label
                                    x:Name="EditorHintLabel"
                                    Text="Create a product with price, stock, and carbon data."
                                    FontSize="13"
                                    TextColor="{StaticResource Muted}"
                                    LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <Button
                                Grid.Column="1"
                                Text="Clear"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnClearProductFormClicked"
                                HeightRequest="40"
                                CornerRadius="10"
                                VerticalOptions="Center" />
                        </Grid>

                        <Entry
                            x:Name="NameEntry"
                            Placeholder="Product name"
                            HeightRequest="44" />

                        <Entry
                            x:Name="CategoryEntry"
                            Placeholder="Category"
                            HeightRequest="44" />

                        <Entry
                            x:Name="DescriptionEntry"
                            Placeholder="Description"
                            HeightRequest="44" />

                        <Grid
                            ColumnDefinitions="*,*,*"
                            ColumnSpacing="8">

                            <Entry
                                x:Name="PriceEntry"
                                Keyboard="Numeric"
                                Placeholder="Price"
                                HeightRequest="44" />

                            <Entry
                                x:Name="StockEntry"
                                Grid.Column="1"
                                Keyboard="Numeric"
                                Placeholder="Stock"
                                HeightRequest="44" />

                            <Entry
                                x:Name="CarbonEntry"
                                Grid.Column="2"
                                Keyboard="Numeric"
                                Placeholder="kg CO2e"
                                HeightRequest="44" />
                        </Grid>

                        <Grid
                            ColumnDefinitions="*,Auto"
                            ColumnSpacing="8">

                            <Button
                                x:Name="SaveProductButton"
                                Text="Add Product"
                                Clicked="OnSaveProductClicked"
                                HeightRequest="46"
                                CornerRadius="12" />

                            <Button
                                x:Name="DeleteSelectedProductButton"
                                Grid.Column="1"
                                Text="Delete"
                                Style="{StaticResource DangerButton}"
                                Clicked="OnDeleteSelectedProductClicked"
                                IsVisible="False"
                                HeightRequest="46"
                                CornerRadius="12" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource CardFrame}"
                    Padding="16"
                    BackgroundColor="White">

                    <VerticalStackLayout Spacing="12">
                        <Grid
                            ColumnDefinitions="*,Auto"
                            ColumnSpacing="8">

                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Products and Stock"
                                    FontSize="20"
                                    FontAttributes="Bold" />

                                <Label
                                    x:Name="ProductCountLabel"
                                    FontSize="13"
                                    TextColor="{StaticResource Muted}" />
                            </VerticalStackLayout>
                        </Grid>

                        <CollectionView
                            x:Name="MerchantProductsView"
                            SelectionMode="None"
                            HeightRequest="340">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Style="{StaticResource CardFrame}"
                                        Margin="0,0,0,10"
                                        Padding="12"
                                        BackgroundColor="{StaticResource Surface}">

                                        <Grid
                                            ColumnDefinitions="*,Auto"
                                            ColumnSpacing="12"
                                            VerticalOptions="Center">

                                            <VerticalStackLayout Spacing="6">
                                                <Label
                                                    Text="{Binding Name}"
                                                    FontAttributes="Bold"
                                                    FontSize="16"
                                                    LineBreakMode="TailTruncation" />

                                                <Label
                                                    Text="{Binding Category}"
                                                    FontSize="13"
                                                    TextColor="{StaticResource Muted}" />

                                                <HorizontalStackLayout Spacing="12">
                                                    <Label
                                                        Text="{Binding Price, StringFormat='${0:F2}'}"
                                                        FontSize="13" />

                                                    <Label
                                                        Text="{Binding CarbonKgPerUnit, StringFormat='{0:F2} kg CO2e'}"
                                                        FontSize="13" />

                                                    <Label
                                                        Text="{Binding StockQuantity, StringFormat='Stock {0}'}"
                                                        FontSize="13"
                                                        FontAttributes="Bold" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Spacing="6"
                                                VerticalOptions="Center">

                                                <HorizontalStackLayout Spacing="6">
                                                    <Button
                                                        Text="-"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Clicked="OnDecreaseStockClicked"
                                                        WidthRequest="38"
                                                        HeightRequest="36"
                                                        CornerRadius="9" />

                                                    <Button
                                                        Text="+"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Clicked="OnIncreaseStockClicked"
                                                        WidthRequest="38"
                                                        HeightRequest="36"
                                                        CornerRadius="9" />
                                                </HorizontalStackLayout>

                                                <Button
                                                    Text="Edit"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Clicked="OnEditProductClicked"
                                                    HeightRequest="36"
                                                    CornerRadius="9" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Row="1"
                    Style="{StaticResource CardFrame}"
                    Padding="16"
                    BackgroundColor="White">

                    <VerticalStackLayout Spacing="12">
                        <Grid
                            ColumnDefinitions="*,Auto"
                            ColumnSpacing="8">

                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Orders"
                                    FontSize="20"
                                    FontAttributes="Bold" />

                                <Label
                                    x:Name="OrderCountLabel"
                                    FontSize="13"
                                    TextColor="{StaticResource Muted}" />
                            </VerticalStackLayout>
                        </Grid>

                        <CollectionView
                            x:Name="MerchantOrdersView"
                            SelectionMode="None"
                            HeightRequest="340">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Style="{StaticResource CardFrame}"
                                        Margin="0,0,0,10"
                                        Padding="12"
                                        BackgroundColor="{StaticResource Surface}">

                                        <Grid
                                            ColumnDefinitions="*,Auto"
                                            ColumnSpacing="12"
                                            VerticalOptions="Center">

                                            <VerticalStackLayout Spacing="6">
                                                <Label
                                                    Text="{Binding CreatedAt, StringFormat='{0:MMM dd, yyyy}'}"
                                                    FontAttributes="Bold"
                                                    FontSize="15" />

                                                <Label
                                                    Text="{Binding Status, StringFormat='Status: {0}'}"
                                                    FontSize="13" />

                                                <HorizontalStackLayout Spacing="12">
                                                    <Label
                                                        Text="{Binding TotalPrice, StringFormat='${0:F2}'}"
                                                        FontSize="13" />

                                                    <Label
                                                        Text="{Binding TotalCarbonKg, StringFormat='{0:F2} kg CO2e'}"
                                                        FontSize="13"
                                                        TextColor="{StaticResource Muted}" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <Button
                                                Grid.Column="1"
                                                Text="Next Status"
                                                Style="{StaticResource SecondaryButton}"
                                                Clicked="OnAdvanceOrderStatusClicked"
                                                HeightRequest="40"
                                                CornerRadius="10"
                                                VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Style="{StaticResource CardFrame}"
                    Padding="16"
                    BackgroundColor="White">

                    <VerticalStackLayout Spacing="12">
                        <Grid
                            ColumnDefinitions="*,Auto"
                            ColumnSpacing="8">

                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Notifications"
                                    FontSize="20"
                                    FontAttributes="Bold" />

                                <Label
                                    x:Name="NotificationCountLabel"
                                    FontSize="13"
                                    TextColor="{StaticResource Muted}" />
                            </VerticalStackLayout>

                            <Button
                                Grid.Column="1"
                                Text="Mark Read"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnMarkNotificationsReadClicked"
                                HeightRequest="40"
                                CornerRadius="10"
                                VerticalOptions="Center" />
                        </Grid>

                        <CollectionView
                            x:Name="MerchantNotificationsView"
                            SelectionMode="None"
                            HeightRequest="340">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Style="{StaticResource CardFrame}"
                                        Margin="0,0,0,10"
                                        Padding="12"
                                        BackgroundColor="{StaticResource Surface}">

                                        <VerticalStackLayout Spacing="6">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label
                                                    Text="{Binding Title}"
                                                    FontAttributes="Bold"
                                                    FontSize="15"
                                                    LineBreakMode="TailTruncation" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="{Binding IsRead, StringFormat='Read: {0}'}"
                                                    FontSize="12"
                                                    TextColor="{StaticResource Muted}" />
                                            </Grid>

                                            <Label
                                                Text="{Binding Message}"
                                                FontSize="13"
                                                TextColor="{StaticResource Muted}"
                                                LineBreakMode="WordWrap" />

                                            <Label
                                                Text="{Binding CreatedAt, StringFormat='{0:MMM dd, HH:mm}'}"
                                                FontSize="12"
                                                TextColor="{StaticResource Muted}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>