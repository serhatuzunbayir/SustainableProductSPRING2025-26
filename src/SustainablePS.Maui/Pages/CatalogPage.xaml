<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SustainablePS.Maui.Pages.CatalogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Catalog"
    BackgroundColor="#F7F8FA">

    <Grid
        RowDefinitions="Auto,*,Auto"
        RowSpacing="14"
        Padding="20,16">

        <VerticalStackLayout Spacing="6">
            <Label
                Text="Eco Product Catalog"
                FontSize="26"
                FontAttributes="Bold" />

            <Label
                Text="Signed in as customer@sustainable.test"
                FontSize="13"
                TextColor="{StaticResource Muted}" />
        </VerticalStackLayout>

        <CollectionView
            x:Name="ProductsView"
            Grid.Row="1"
            SelectionMode="None"
            Margin="0,4,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Style="{StaticResource CardFrame}"
                        Margin="0,0,0,10"
                        Padding="14"
                        BackgroundColor="White">

                        <Grid
                            ColumnDefinitions="*,Auto"
                            ColumnSpacing="12"
                            VerticalOptions="Center">

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    Text="{Binding Name}"
                                    FontAttributes="Bold"
                                    FontSize="17"
                                    LineBreakMode="TailTruncation" />

                                <Label
                                    Text="{Binding Description}"
                                    FontSize="14"
                                    TextColor="{StaticResource Muted}"
                                    LineBreakMode="WordWrap" />

                                <HorizontalStackLayout Spacing="12">
                                    <Label
                                        Text="{Binding Price, StringFormat='${0:F2}'}"
                                        FontAttributes="Bold"
                                        FontSize="14" />

                                    <Label
                                        Text="{Binding CarbonKgPerUnit, StringFormat='{0:F2} kg CO2e/unit'}"
                                        FontSize="13" />

                                    <Label
                                        Text="{Binding StockQuantity, StringFormat='Stock {0}'}"
                                        FontSize="13"
                                        TextColor="{StaticResource Muted}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Button
                                Grid.Column="1"
                                Text="Add"
                                Clicked="OnAddToCartClicked"
                                HeightRequest="42"
                                CornerRadius="10"
                                Padding="14,0"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border
            Grid.Row="2"
            Style="{StaticResource CardFrame}"
            Padding="16"
            BackgroundColor="White">

            <Grid
                ColumnDefinitions="*,Auto"
                ColumnSpacing="12"
                VerticalOptions="Center">

                <VerticalStackLayout Spacing="4">
                    <Label
                        x:Name="CartCountLabel"
                        FontAttributes="Bold"
                        FontSize="16" />

                    <Label
                        x:Name="CartCarbonLabel"
                        FontSize="13"
                        TextColor="{StaticResource Muted}" />
                </VerticalStackLayout>

                <Button
                    Grid.Column="1"
                    Text="View Cart"
                    Clicked="OnViewCartClicked"
                    HeightRequest="44"
                    CornerRadius="12"
                    Padding="16,0"
                    VerticalOptions="Center" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>