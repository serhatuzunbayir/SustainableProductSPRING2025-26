<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SustainablePS.Maui.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dashboard"
    BackgroundColor="#F7F8FA">

    <ScrollView>
        <VerticalStackLayout
            Spacing="16"
            Padding="20,16">

            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Carbon Dashboard"
                    FontSize="26"
                    FontAttributes="Bold" />

                <Label
                    Text="Customer purchase history and carbon totals"
                    FontSize="13"
                    TextColor="{StaticResource Muted}" />
            </VerticalStackLayout>

            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="10">

                <Border
                    Style="{StaticResource CardFrame}"
                    Padding="16"
                    BackgroundColor="White">

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Total CO2e"
                            FontSize="13"
                            TextColor="{StaticResource Muted}" />

                        <Label
                            x:Name="TotalCarbonLabel"
                            FontSize="24"
                            FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource CardFrame}"
                    Padding="16"
                    BackgroundColor="White">

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Orders"
                            FontSize="13"
                            TextColor="{StaticResource Muted}" />

                        <Label
                            x:Name="OrderCountLabel"
                            FontSize="24"
                            FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Label
                Text="Monthly Carbon"
                FontSize="18"
                FontAttributes="Bold"
                Margin="0,4,0,0" />

            <Border
                Style="{StaticResource CardFrame}"
                Padding="12"
                BackgroundColor="White">

                <CollectionView
                    x:Name="MonthlyView"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                ColumnDefinitions="*,Auto"
                                Padding="4,8">

                                <Label
                                    Text="{Binding Label}"
                                    FontSize="14" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding CarbonKg, StringFormat='{0:F2} kg CO2e'}"
                                    FontSize="14"
                                    FontAttributes="Bold" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Label
                Text="Purchase History"
                FontSize="18"
                FontAttributes="Bold"
                Margin="0,4,0,0" />

            <CollectionView
                x:Name="HistoryView"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Style="{StaticResource CardFrame}"
                            Margin="0,0,0,10"
                            Padding="14"
                            BackgroundColor="White">

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    Text="{Binding CreatedAt, StringFormat='{0:MMM dd, yyyy}'}"
                                    FontAttributes="Bold"
                                    FontSize="16" />

                                <Label
                                    Text="{Binding TotalPrice, StringFormat='${0:F2}'}"
                                    FontSize="14" />

                                <Label
                                    Text="{Binding TotalCarbonKg, StringFormat='{0:F2} kg CO2e'}"
                                    FontSize="13"
                                    TextColor="{StaticResource Muted}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>